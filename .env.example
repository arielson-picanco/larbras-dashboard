# ============================================================
# LARBRAS — Variáveis de ambiente
# Copie para .env.local e preencha suas chaves.
# ============================================================

# ── Google Gemini 2.0 Flash (GRATUITO — recomendado) ─────────
# https://aistudio.google.com/app/apikey  →  clique "Create API key"
VITE_GEMINI_API_KEY=AIzaSy...

# ── Groq — Llama 3 8B (GRATUITO e muito rápido) ──────────────
# https://console.groq.com/keys  →  clique "Create API key"
VITE_GROQ_API_KEY=gsk_...

# ── Anthropic Claude (pago — saldo necessário) ────────────────
# https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Modo de operação ──────────────────────────────────────────
VITE_USE_API=false
VITE_API_URL=http://localhost:3001/api
